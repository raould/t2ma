(program
    (import * as Phaser "phaser")
    (class Scene1 (extends Phaser.Scene)
        (class-body
            (constructor () (super "Scene1"))
            (method preload ()
                (console.log "preload")
                (this.load.image "gem" "resoures/assets/gem6.png")
            )
            (method create () (console.log "create")
        )
    ))
    (const* (
        (config {
            type: Phaser.AUTO,
            width: 640,
            height: 480,
            scene: (new Scene1),
        })
        (game (new Phaser.Game config))
    ))
)